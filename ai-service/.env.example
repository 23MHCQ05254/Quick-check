# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/

# JWT Secret (change in production!)
JWT_SECRET=dev-secret-key-change-in-production

# Tesseract OCR Path (optional - auto-detected if in PATH)
# On Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# On Linux: /usr/bin/tesseract
# Leave blank to auto-detect
TESSERACT_PATH=

# Poppler Path (optional - for PDF conversion)
# On Windows: C:\Program Files\poppler\Library\bin
# On Linux: /usr/bin (if poppler-utils installed)
# Leave blank to auto-detect
POPPLER_PATH=

# Service Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=false
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
